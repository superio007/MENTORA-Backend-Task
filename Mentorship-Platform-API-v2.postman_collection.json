    {
      "name": "🤖 LLM",
      "item": [
        {
          "name": "Summarize Text",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log(\"✅ Summary generated\");",
                  "    console.log(\"📝 Summary: \" + jsonData.summary.substring(0, 100) + \"...\");",
                  "    console.log(\"📊 Word count: \" + jsonData.wordCount);",
                  "    console.log(\"🔹 Bullet points: \" + (jsonData.bulletPoints ? jsonData.bulletPoints.length : 0));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"JavaScript is a versatile programming language that powers interactive web applications. It runs in browsers and can also be used on servers with Node.js. JavaScript supports both functional and object-oriented programming paradigms. The language has evolved significantly with ES6 introducing classes, arrow functions, and modules. Modern JavaScript frameworks like React, Vue, and Angular have revolutionized web development. Asynchronous programming with promises and async/await makes handling operations like API calls more manageable. JavaScript's flexibility and widespread adoption make it one of the most popular programming languages today.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/llm/summarize",
              "host": ["{{base_url}}"],
              "path": ["llm", "summarize"]
            },
            "description": "Generate a text summary using AI (Authenticated users only)"
          },
          "response": []
        }
      ]
